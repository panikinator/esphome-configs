{
    "servers": {
        "docsmcp": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "docsmcp",
                "'--source=official esphome documentation website|https://esphome.io/components'",
                "'--source=official espressif esp32 arduino-core documentation website|https://docs.espressif.com/projects/arduino-esp32/en/latest/'",
            ]
        },
        "Esphome Docs": {
            "url": "https://gitmcp.io/esphome/esphome-docs"
        },
        "Esphome Developer Docs": {
            "type": "sse",
            "url": "https://gitmcp.io/esphome/developers.esphome.io"
        },
        "Esphome source code": {
            "type": "sse",
            "url": "https://gitmcp.io/esphome/esphome"
        },
        "syssi/esphome-jk-bms Docs": {
            "type": "sse",
            "url": "https://gitmcp.io/syssi/esphome-jk-bms"
        }
    }
}
